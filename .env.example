# Database
DATABASE_URL=postgresql://minecraft_user:minecraft_password_change_me@localhost:5432/minecraft_hosting

# Redis
REDIS_URL=redis://:redis_password_change_me@localhost:6379

# JWT
JWT_SECRET=your_jwt_secret_change_me_with_something_long_and_secure

# NextAuth
NEXTAUTH_SECRET=your_nextauth_secret_change_me_with_something_long_and_secure
NEXTAUTH_URL=http://localhost:3000

# API
API_PORT=3001
API_HOST=localhost

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:3001/api
NEXT_PUBLIC_APP_NAME=PlayHost

# Email (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# DDoS Protection
DDOS_RATE_LIMIT=100
DDOS_WINDOW_MS=15000

# Server Settings
MAX_SERVERS_PER_USER=5
MAX_RAM_PER_USER=8192
MAX_CPU_CORES=4
DEFAULT_PORT_RANGE=25565-25595